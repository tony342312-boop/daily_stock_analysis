# Copy this file to /opt/daily_stock_analysis/.env and fill real secrets.
# Do not commit real API keys.

# ----- Runtime -----
DATABASE_PATH=./data/stock_analysis.db
WEBUI_ENABLED=false
WEBUI_HOST=127.0.0.1
WEBUI_PORT=8000
WEBUI_AUTO_BUILD=false
REPORT_LANGUAGE=zh

# Enable before exposing the service to other users.
ADMIN_AUTH_ENABLED=true

# ----- LLM: fill at least one provider -----
GEMINI_API_KEY=
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
# DEEPSEEK_API_KEY=
# AIHUBMIX_KEY=

# ----- Search / research sources -----
TAVILY_API_KEYS=
EXA_API_KEY=
FRED_API_KEY=
SEC_EDGAR_ENABLED=true
SEC_EDGAR_USER_AGENT=daily_stock_analysis/1.0 admin@stock.cn.mt

# ----- Market data, optional -----
TUSHARE_TOKEN=
# LONGBRIDGE_APP_KEY=
# LONGBRIDGE_APP_SECRET=
# LONGBRIDGE_ACCESS_TOKEN=

# ----- Optional proxy -----
# USE_PROXY=false
# PROXY_HOST=127.0.0.1
# PROXY_PORT=10809
